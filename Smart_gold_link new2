    <!-- ===== جافا سكريبت محسّن ===== -->
    <script>
        (function() {
            "use strict";

            // ===== 1. تعيين تاريخ اليوم تلقائياً =====
            function setDefaultDate() {
                const today = new Date();
                const yyyy = today.getFullYear();
                const mm = String(today.getMonth() + 1).padStart(2, '0');
                const dd = String(today.getDate()).padStart(2, '0');
                const dateInput = document.getElementById('visitDate');
                if (dateInput) {
                    dateInput.value = `${yyyy}-${mm}-${dd}`;
                }
            }

            // ===== 2. التحقق من صحة الحقول المطلوبة =====
            function validateForm() {
                const brand = document.getElementById('applianceBrand').value.trim();
                const issue = document.getElementById('applianceIssue').value.trim();
                const area = document.getElementById('customerArea').value.trim();
                const street = document.getElementById('customerStreet').value.trim();
                const floor = document.getElementById('customerFloor').value.trim();
                const phone = document.getElementById('customerPhone').value.trim();

                // التحقق من أن جميع الحقول مليئة
                if (!brand || !issue || !area || !street || !floor || !phone) {
                    showError('يرجى تعبئة كافة الحقول المطلوبة (العلامة التجارية، وصف العطل، المنطقة، الشارع، الطابق، الهاتف).');
                    return false;
                }

                // التحقق من صحة رقم الهاتف (أرقام فقط وتبدأ بـ 07 أو 05)
                const phoneRegex = /^(07|05)[0-9]{8}$/;
                if (!phoneRegex.test(phone)) {
                    showError('رقم الهاتف غير صحيح. يجب أن يتكون من 10 أرقام ويبدأ بـ 07 أو 05 (مثال: 0790252605).');
                    return false;
                }

                hideError();
                return true;
            }

            // ===== 3. عرض/إخفاء رسائل الخطأ =====
            function showError(msg) {
                const errDiv = document.getElementById('errorNotification');
                errDiv.textContent = '❌ ' + msg;
                errDiv.style.display = 'block';
                // إخفاء رسالة النجاح إذا ظهرت
                document.getElementById('saveNotification').style.display = 'none';
            }
            function hideError() {
                document.getElementById('errorNotification').style.display = 'none';
            }

            // ===== 4. حفظ البيانات وتفعيل زر الواتساب =====
            window.saveDataProgress = function() {
                if (validateForm()) {
                    // إظهار رسالة النجاح
                    document.getElementById('saveNotification').style.display = 'block';
                    // تفعيل زر الواتساب
                    const whatsappBtn = document.getElementById('whatsappBtn');
                    whatsappBtn.classList.add('active');
                    // إخفاء أي رسالة خطأ سابقة
                    hideError();
                }
            };

            // ===== 5. إرسال البيانات عبر الواتساب =====
            window.sendToWhatsapp = function() {
                const whatsappBtn = document.getElementById('whatsappBtn');
                if (!whatsappBtn.classList.contains('active')) {
                    alert('⚠️ يرجى الضغط على "حفظ بيانات الطلب" أولاً للتأكد من صحة المدخلات.');
                    return;
                }

                // جمع البيانات
                const applianceType = document.getElementById('applianceType').value;
                const applianceBrand = document.getElementById('applianceBrand').value.trim();
                const applianceIssue = document.getElementById('applianceIssue').value.trim();
                const visitDate = document.getElementById('visitDate').value;
                const customerCity = document.getElementById('customerCity').value;
                const customerArea = document.getElementById('customerArea').value.trim();
                const customerStreet = document.getElementById('customerStreet').value.trim();
                const customerFloor = document.getElementById('customerFloor').value.trim();
                const customerPhone = document.getElementById('customerPhone').value.trim();

                // بناء نص الرسالة (تم ترميزه لـ URL)
                const baseMessage = 
                    `*طلب صيانة صادر عن الموقع الإلكتروني لشركة سمارت جولد لينك*%0A%0A` +
                    `*🛠️ تفاصيل البلاغ:*%0A` +
                    `- نوع الجهاز: ${encodeURIComponent(applianceType)}%0A` +
                    `- ماركة الجهاز: ${encodeURIComponent(applianceBrand)}%0A` +
                    `- وصف المشكلة: ${encodeURIComponent(applianceIssue)}%0A` +
                    `- تاريخ الزيارة المطلوبة: ${encodeURIComponent(visitDate)}%0A%0A` +
                    `*📍 موقع العميل المعتمد:*%0A` +
                    `- المحافظة: ${encodeURIComponent(customerCity)}%0A` +
                    `- المنطقة/الحي: ${encodeURIComponent(customerArea)}%0A` +
                    `- الشارع/العمارة: ${encodeURIComponent(customerStreet)}%0A` +
                    `- الطابق/الشقة: ${encodeURIComponent(customerFloor)}%0A%0A` +
                    `*📞 رقم اتصال التنسيق:*%0A` +
                    `- الهاتف: ${encodeURIComponent(customerPhone)}`;

                // رقم الواتساب (مع رمز الدولة الأردن 962)
                const phoneNumber = '962790252605';
                const url = `https://wa.me/${phoneNumber}?text=${baseMessage}`;

                // فتح الرابط في تبويب جديد
                window.open(url, '_blank');
            };

            // ===== 6. إعادة تعيين النموذج =====
            window.resetForm = function() {
                document.getElementById('maintenanceForm').reset();
                // إعادة تعيين التاريخ إلى اليوم الحالي
                setDefaultDate();
                // إخفاء الرسائل
                document.getElementById('saveNotification').style.display = 'none';
                document.getElementById('errorNotification').style.display = 'none';
                // إلغاء تفعيل زر الواتساب
                const whatsappBtn = document.getElementById('whatsappBtn');
                whatsappBtn.classList.remove('active');
            };

            // ===== 7. تهيئة الصفحة =====
            document.addEventListener('DOMContentLoaded', function() {
                setDefaultDate();
                // إضافة مستمع للتحقق الفوري عند تغيير الحقول (اختياري)
                // يمكنك إضافة validation on blur إذا أردت
            });

        })();
    </script>

