            align-items: center;
            flex-wrap: wrap;
            gap: 25px;
            padding-bottom: 30px;
            border-bottom: 2px solid #eaeef5;
            margin-bottom: 35px;
        }

        .brand-area {
            flex: 2;
            min-width: 250px;
        }

        .brand-area h1 {
