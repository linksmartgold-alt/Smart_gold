                                    <option value="شاشة ذكية / تلفزيون">شاشة ذكية / تلفزيون</option>
                                    <option value="جهاز مطبخ صغير">جهاز مطبخ صغير</option>
                                </select>
                            </div>

                            <!-- الماركة -->
                            <div class="form-group">
                                <label for="applianceBrand">
                                    الماركة / الصانع
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <input type="text" id="applianceBrand" placeholder="مثال: LG, Sharp, Vestel..." required aria-required="true" maxlength="60">
                            </div>

                            <!-- وصف العطل -->
                            <div class="form-group full-width">
                                <label for="applianceIssue">
                                    وصف العطل بالتفصيل
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <textarea id="applianceIssue" placeholder="اكتب مشكلة الجهاز بوضوح لتسهيل مهمة الفني..." required aria-required="true" maxlength="300"></textarea>
                            </div>

                            <!-- تاريخ الزيارة -->
                            <div class="form-group">
                                <label for="visitDate">
                                    تاريخ الزيارة المطلوبة
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <input type="date" id="visitDate" required aria-required="true">
                            </div>

                            <!-- المحافظة -->
                            <div class="form-group">
                                <label for="customerCity">المحافظة</label>
                                <select id="customerCity">
                                    <option value="العاصمة عمان">العاصمة عمان</option>
                                    <option value="إربد">إربد</option>
                                    <option value="الزرقاء">الزرقاء</option>
                                    <option value="البلقاء">البلقاء</option>
                                    <option value="المفرق">المفرق</option>
                                    <option value="جرش">جرش</option>
                                    <option value="عجلون">عجلون</option>
                                    <option value="مأدبا">مأدبا</option>
                                    <option value="الكرك">الكرك</option>
                                    <option value="الطفيلة">الطفيلة</option>
                                    <option value="معان">معان</option>
                                    <option value="العقبة">العقبة</option>
                                </select>
                            </div>

                            <!-- الحي -->
                            <div class="form-group">
                                <label for="customerArea">
                                    الحي / المنطقة
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <input type="text" id="customerArea" placeholder="مثال: العبدلي، تلاع العلي..." required aria-required="true" maxlength="60">
                            </div>

                            <!-- الشارع -->
                            <div class="form-group">
                                <label for="customerStreet">
                                    الشارع واسم العمارة
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <input type="text" id="customerStreet" placeholder="رقم أو اسم الشارع والعمارة" required aria-required="true" maxlength="80">
                            </div>

                            <!-- الطابق -->
                            <div class="form-group">
                                <label for="customerFloor">
                                    الطابق / رقم الشقة
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <input type="text" id="customerFloor" placeholder="مثال: طابق 2، شقة 5" required aria-required="true" maxlength="40">
                            </div>

                            <!-- الهاتف -->
                            <div class="form-group full-width">
                                <label for="customerPhone">
                                    رقم الهاتف للتنسيق
                                    <span class="required-star" aria-hidden="true">*</span>
                                </label>
                                <input type="tel" id="customerPhone" placeholder="07XXXXXXXX" inputmode="numeric" required aria-required="true" maxlength="10" pattern="[0-9]{10}">
                                <small style="color:var(--text-muted); font-size:12px;">يجب أن يتكون من 10 أرقام ويبدأ بـ 07 أو 05.</small>
                            </div>
                        </div>

                        <!-- رسائل الحالة -->
                        <div id="saveNotification" class="status-msg status-success" role="status" aria-live="polite">
                            ✅ تم حفظ بيانات الطلب في المتصفح بنجاح! يمكنك الآن إرسالها عبر واتساب.
                        </div>
                        <div id="errorNotification" class="status-msg status-error" role="alert" aria-live="assertive">
                            ⚠️ يرجى تصحيح الأخطاء في الحقول المحددة.
                        </div>

                        <!-- الأزرار -->
                        <div class="action-buttons">
                            <button type="button" onclick="saveDataProgress()" class="btn btn-save">
                                💾 حفظ البيانات (الخطوة 1)
                            </button>
                            <button type="button" onclick="sendToWhatsapp()" id="whatsappBtn" class="btn btn-whatsapp">
                                🚀 إرسال للواتساب (الخطوة 2)
                            </button>
                            <button type="button" onclick="resetForm()" class="btn btn-reset">
                                🔄 إعادة تعيين
                            </button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- ===== التذييل ===== -->
            <footer>
                <div class="footer-links">
                    <a href="https://www.instagram.com/fahed_ayel_slman?igsh=MWF2Mm83aG1rODZhdQ==" target="_blank" rel="noopener noreferrer">
                        📸 إنستغرام
                    </a>
                    <a href="https://www.youtube.com/@fahdhatmalalsudi" target="_blank" rel="noopener noreferrer">
                        🎥 يوتيوب
                    </a>
                    <a href="#" onclick="alert('سيتم إضافة سياسة الخصوصية قريباً. بياناتك آمنة ولا تُشارَك مع أطراف أخرى.'); return false;">
                        🔒 سياسة الخصوصية
                    </a>
                </div>
                <div class="footer-copy">
                    جميع الحقوق محفوظة © <strong>شركة سمارت جولد لينك للأجهزة والتكييف</strong><br>
                    بإشراف المدير العام: السيد فهد السعودي | المقر الرئيسي: عمان - العبدلي - الأردن
                </div>
                <div class="privacy-note">
                    🔐 يتم تخزين بياناتك محلياً في متصفحك لحماية خصوصيتك، ولن تُرسل إلا عند تأكيد إرسال الطلب عبر واتساب.
                </div>
            </footer>

        </div>
    </div>

    <!-- ===== جافا سكريبت متقدم واحترافي ===== -->
    <script>
        (function() {
            'use strict';

            // ===== 1. الكاش والمتغيرات =====
            const FORM = document.getElementById('maintenanceForm');
            const FIELDS = {
                type: document.getElementById('applianceType'),
                brand: document.getElementById('applianceBrand'),
                issue: document.getElementById('applianceIssue'),
                date: document.getElementById('visitDate'),
                city: document.getElementById('customerCity'),
                area: document.getElementById('customerArea'),
                street: document.getElementById('customerStreet'),
                floor: document.getElementById('customerFloor'),
                phone: document.getElementById('customerPhone')
            };
            const MSG_SUCCESS = document.getElementById('saveNotification');
            const MSG_ERROR = document.getElementById('errorNotification');
            const WHATSAPP_BTN = document.getElementById('whatsappBtn');

            const STORAGE_KEY = 'smartGoldLink_appData';
            const PHONE_REGEX = /^(07|05)[0-9]{8}$/;

            // ===== 2. تهيئة التاريخ ومنع الاختيار السابق =====
            function initDate() {
                const today = new Date();
                const yyyy = today.getFullYear();
                const mm = String(today.getMonth() + 1).padStart(2, '0');
                const dd = String(today.getDate()).padStart(2, '0');
                const todayStr = `${yyyy}-${mm}-${dd}`;
                FIELDS.date.setAttribute('min', todayStr);
                if (!FIELDS.date.value) {
                    FIELDS.date.value = todayStr;
                }
            }

            // ===== 3. منع الأحرف غير الرقمية في حقل الهاتف =====
            function restrictPhoneInput() {
                FIELDS.phone.addEventListener('input', function() {
                    this.value = this.value.replace(/\D/g, '').slice(0, 10);
                });
            }

            // ===== 4. تحميل البيانات المحفوظة =====
            function loadSavedData() {
                try {
                    const saved = localStorage.getItem(STORAGE_KEY);
                    if (!saved) return;
                    const data = JSON.parse(saved);
                    for (const [key, field] of Object.entries(FIELDS)) {
                        if (data[key] !== undefined && data[key] !== null && data[key] !== '') {
                            field.value = data[key];
                        }
                    }
                    // إذا كان التاريخ محفوظاً وتجاوز اليوم، نعيد تعيينه لليوم
                    const today = new Date().toISOString().slice(0, 10);
                    if (FIELDS.date.value && FIELDS.date.value < today) {
                        FIELDS.date.value = today;
                    }
                    // تفعيل زر الواتساب إذا كانت البيانات موجودة
                    if (data._isValid) {
                        WHATSAPP_BTN.classList.add('active');
                    }
                } catch (e) {
                    console.warn('فشل تحميل البيانات المخزنة:', e);
                }
            }

            // ===== 5. حفظ البيانات =====
            function saveToStorage(valid) {
                const data = {};
                for (const [key, field] of Object.entries(FIELDS)) {
                    data[key] = field.value;
                }
                data._isValid = valid || false;
                try {
                    localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
                } catch (e) {
                    console.warn('فشل حفظ البيانات:', e);
                }
            }

            // ===== 6. التحقق من النموذج =====
            function validateForm() {
                const brand = FIELDS.brand.value.trim();
                const issue = FIELDS.issue.value.trim();
                const area = FIELDS.area.value.trim();
                const street = FIELDS.street.value.trim();
                const floor = FIELDS.floor.value.trim();
                const phone = FIELDS.phone.value.trim();

                if (!brand || !issue || !area || !street || !floor || !phone) {
                    showError('جميع الحقول المطلوبة (ذات العلامة *) يجب تعبئتها.');
                    return false;
                }

                if (!PHONE_REGEX.test(phone)) {
                    showError('رقم الهاتف غير صحيح. يجب أن يبدأ بـ 07 أو 05 ويتكون من 10 أرقام.');
                    return false;
                }

                hideError();
                return true;
            }

            // ===== 7. عرض/إخفاء الرسائل =====
            function showError(msg) {
                MSG_ERROR.textContent = '⚠️ ' + msg;
                MSG_ERROR.style.display = 'flex';
                MSG_SUCCESS.style.display = 'none';
            }

            function hideError() {
                MSG_ERROR.style.display = 'none';
            }

            function showSuccess() {
                MSG_SUCCESS.style.display = 'flex';
                MSG_ERROR.style.display = 'none';
                // إخفاء رسالة النجاح بعد 6 ثوانٍ
                clearTimeout(window._successTimer);
                window._successTimer = setTimeout(() => {
                    MSG_SUCCESS.style.display = 'none';
                }, 6000);
            }

            // ===== 8. حفظ البيانات وتفعيل زر الواتساب =====
            window.saveDataProgress = function() {
                if (validateForm()) {
                    saveToStorage(true);
                    WHATSAPP_BTN.classList.add('active');
                    showSuccess();
                } else {
                    saveToStorage(false);
                    WHATSAPP_BTN.classList.remove('active');
                }
            };

            // ===== 9. الإرسال عبر واتساب =====
            window.sendToWhatsapp = function() {
                if (!WHATSAPP_BTN.classList.contains('active')) {
                    alert('⚠️ يرجى الضغط على "حفظ البيانات" أولاً والتأكد من صحة المدخلات.');
                    return;
                }

                // التأكد من صحة البيانات مرة أخيرة
                if (!validateForm()) {
                    WHATSAPP_BTN.classList.remove('active');
                    saveToStorage(false);
                    return;
                }

                // جمع البيانات
                const type = FIELDS.type.value;
                const brand = FIELDS.brand.value.trim();
                const issue = FIELDS.issue.value.trim();
                const date = FIELDS.date.value;
                const city = FIELDS.city.value;
                const area = FIELDS.area.value.trim();
                const street = FIELDS.street.value.trim();
                const floor = FIELDS.floor.value.trim();
                const phone = FIELDS.phone.value.trim();

                // بناء رسالة منسقة بشكل احترافي (مع ترميز URL)
                const lines = [
                    '*📋 طلب صيانة - سمارت جولد لينك*',
                    '',
                    '*🛠️ تفاصيل الجهاز:*',
                    `▪️ النوع: ${type}`,
                    `▪️ الماركة: ${brand}`,
                    `▪️ العطل: ${issue}`,
                    `▪️ التاريخ: ${date}`,
                    '',
                    '*📍 موقع العميل:*',
                    `▪️ المحافظة: ${city}`,
                    `▪️ الحي: ${area}`,
                    `▪️ الشارع: ${street}`,
                    `▪️ الطابق: ${floor}`,
                    '',
                    '*📞 للتواصل:*',
                    `▪️ الهاتف: ${phone}`
                ];

                const message = lines.join('%0A');
                const phoneNumber = '+962790252605';
                const url = `https://wa.me/${phoneNumber}?text=${message}`;

                // فتح الرابط مع تأكيد بسيط
                if (confirm('✅ سيتم توجيهك إلى تطبيق واتساب لإرسال الطلب. هل البيانات صحيحة؟')) {
                    window.open(url, '_blank');
                }
            };

            // ===== 10. إعادة تعيين النموذج =====
            window.resetForm = function() {
                if (!confirm('⚠️ هل أنت متأكد من مسح جميع البيانات المدخلة؟')) return;

                FORM.reset();
                initDate();
                localStorage.removeItem(STORAGE_KEY);
                WHATSAPP_BTN.classList.remove('active');
                MSG_SUCCESS.style.display = 'none';
                MSG_ERROR.style.display = 'none';
                // تنظيف أي بيانات متبقية في الحقول
                for (const field of Object.values(FIELDS)) {
                    if (field.tagName === 'SELECT') {
                        field.selectedIndex = 0;
                    }
                }
                // إعادة تعيين حقل الهاتف
                FIELDS.phone.value = '';
                // إعادة تعيين التاريخ
                initDate();
            };

            // ===== 11. تهيئة الصفحة =====
            document.addEventListener('DOMContentLoaded', function() {
                initDate();
                restrictPhoneInput();
                loadSavedData();

                // حفظ تلقائي عند تغيير أي حقل (للتخزين المؤقت)
                for (const field of Object.values(FIELDS)) {
                    field.addEventListener('change', function() {
                        // نتحقق من الصحة ونحفظ الحالة الحالية
                        const isValid = validateForm();
                        saveToStorage(isValid);
                        if (isValid) {
                            WHATSAPP_BTN.classList.add('active');
                            // نعرض رسالة نجاح مختصرة ولكن لا نزعج المستخدم
                            MSG_SUCCESS.style.display = 'flex';
                            clearTimeout(window._successTimer);
                            window._successTimer = setTimeout(() => {
                                MSG_SUCCESS.style.display = 'none';
                            }, 3000);
                        } else {
                            WHATSAPP_BTN.classList.remove('active');
                            MSG_SUCCESS.style.display = 'none';
                        }
                    });
                    // للهاتف نستخدم input لتحديث فوري
                    if (field.id === 'customerPhone') {
                        field.addEventListener('input', function() {
                            const isValid = validateForm();
                            saveToStorage(isValid);
                            if (isValid) {
                                WHATSAPP_BTN.classList.add('active');
                            } else {
                                WHATSAPP_BTN.classList.remove('active');
                            }
                        });
                    }
                }

                // إضافة اختصار لوحة المفاتيح (Ctrl+Enter لحفظ)
                FORM.addEventListener('keydown', function(e) {
                    if (e.ctrlKey && e.key === 'Enter') {
                        e.preventDefault();
                        saveDataProgress();
                    }
                });
            });

        })();
    </script>

</body>
