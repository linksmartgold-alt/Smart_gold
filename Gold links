        .footer-links a {
            color: var(--royal-blue);
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-bottom: 2px solid transparent;
        }

        .footer-links a:hover {
            color: var(--dark-gold);
            border-bottom-color: var(--gold);
        }

        .footer-copy {
            text-align: center;
            font-size: 13px;
            color: var(--text-muted);
            border-top: 1px solid #eaeef5;
            padding-top: 20px;
            margin-top: 10px;
        }

        .footer-copy strong {
            color: var(--royal-blue);
        }

        .privacy-note {
            font-size: 12px;
            color: #8a9aa8;
            text-align: center;
            margin-top: 10px;
            background: #f4f6f9;
            padding: 10px;
            border-radius: 8px;
        }

        /* ===== 11. استجابة متقدمة ===== */
        @media (max-width: 768px) {
            .main-card {
                padding: 20px;
            }
            .header-grid {
                flex-direction: column;
                align-items: center;
                text-align: center;
            }
            .brand-area h1 {
                font-size: 24px;
            }
            .form-grid {
                grid-template-columns: 1fr;
                gap: 18px;
            }
            .form-group.full-width {
                grid-column: span 1;
            }
            .action-buttons {
                flex-direction: column;
            }
            .btn {
                flex: 1 1 auto;
                width: 100%;
            }
            .jordan-flag-wrapper {
                margin-top: 5px;
            }
            .specs-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .form-box {
                padding: 20px;
            }
        }

        @media (max-width: 480px) {
            .specs-grid {
                grid-template-columns: 1fr;
            }
            .brand-area h1 {
                font-size: 20px;
            }
            .ticker-item {
                font-size: 12px;
                padding: 0 15px;
            }
        }
    </style>
</head>
