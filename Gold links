        .status-success {
            display: flex;
            background: #e8f5e9;
            color: #1e5a2a;
            border-right-color: var(--success-green);
        }

        .status-error {
            display: flex;
            background: #fce4e4;
            color: #7a1c1c;
            border-right-color: var(--danger-red);
        }

        /* ===== 9. الأزرار ===== */
        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 30px;
        }

        .btn {
            flex: 1 1 180px;
            padding: 14px 22px;
            border: none;
            border-radius: 8px;
            font-weight: 700;
            font-size: 15px;
            color: #fff;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            text-decoration: none;
            letter-spacing: 0.3px;
            position: relative;
            overflow: hidden;
        }

        .btn::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255, 255, 255, 0.1);
            opacity: 0;
            transition: var(--transition);
        }

        .btn:hover::after {
            opacity: 1;
        }

        .btn-save {
            background: var(--royal-blue);
            box-shadow: 0 4px 12px rgba(15, 43, 92, 0.25);
        }
        .btn-save:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(15, 43, 92, 0.35);
            background: var(--light-blue);
        }

        .btn-whatsapp {
            background: #a0aaba;
            cursor: not-allowed;
            opacity: 0.6;
            box-shadow: none;
            pointer-events: none;
        }

        .btn-whatsapp.active {
            background: var(--whatsapp-green);
            cursor: pointer;
            opacity: 1;
            pointer-events: auto;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.35);
        }

        .btn-whatsapp.active:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.45);
            background: #1da85e;
        }

        .btn-reset {
            background: #7c879c;
            box-shadow: 0 4px 12px rgba(124, 135, 156, 0.25);
        }
        .btn-reset:hover {
            transform: translateY(-3px);
            background: #5f6a7e;
            box-shadow: 0 8px 20px rgba(124, 135, 156, 0.35);
        }

        /* ===== 10. التذييل ===== */
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 25px;
            flex-wrap: wrap;
            margin: 30px 0 15px;
