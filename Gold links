            gap: 22px 30px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group.full-width {
            grid-column: span 2;
        }

        .form-group label {
            font-weight: 700;
            font-size: 14px;
            color: var(--royal-blue);
            display: flex;
            align-items: center;
            gap: 5px;
